# Shared local development values. Copy to .env before using docker compose.
APP_ENV=development
APP_SECRET=change-me-app-secret
JWT_SECRET=change-me-jwt-secret
ADMIN_SECRET=change-me-admin-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password
ADMIN_EMAIL=admin@adbothost.local
PUBLIC_BASE_URL=http://localhost
API_ROOT_PATH=/api
CORS_ORIGINS=http://localhost,http://localhost:5173,http://127.0.0.1:5173

# Backend
POSTGRES_DB=adbothost
POSTGRES_USER=adbothost
POSTGRES_PASSWORD=adbothost
DATABASE_URL=postgresql+psycopg2://adbothost:adbothost@db:5432/adbothost
BACKEND_BASE_URL=http://backend:8000
FRONTEND_BASE_URL=http://localhost:5173
UPLOAD_DIR=/app/uploads
SCHEDULER_ENABLED=true
AD_REWARD_CREDITS=1
SCAN_MAX_FILE_MB=25
ALLOW_NEGATIVE_CREDITS=false

# Manual payments
MANUAL_PAYMENT_ENABLED=true
MANUAL_PAYMENT_PROVIDER_NAME="Binance Pay"
MANUAL_PAYMENT_RECEIVER_ID=""
MANUAL_PAYMENT_INSTRUCTIONS="Send payment, then submit your Binance ID and TxID."
MANUAL_PAYMENT_CURRENCY="USDT"

# Controller <-> worker signing. In production, use per-node secrets.
DEFAULT_NODE_AGENT_TOKEN=local-node-agent-token
CONTROLLER_SIGNING_SECRET=local-controller-signing-secret

# Worker
NODE_AGENT_TOKEN=local-node-agent-token
WORKER_NAME=local-worker
WORKER_PUBLIC_BASE_URL=http://worker:9000
WORKER_DATA_DIR=/var/lib/adbothost-worker
WORKER_MAX_CONTAINERS=20
WORKER_ENFORCE_STORAGE_OPT=false

# Telegram control bot
TELEGRAM_CONTROL_BOT_TOKEN=
TELEGRAM_BACKEND_URL=http://backend:8000

# Frontend
VITE_API_BASE_URL=http://localhost:8000
